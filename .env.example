# ── קריאה מהגיליון (חובה) ────────────────────────────────────────────────────
# File > Share > Publish to web > בחר: projects > CSV > Publish
# הדבק כאן את ה-URL ללא "?output=csv" (רק עד /pub)
VITE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vT1gPbkvJTIY6ZztmORgUxGiE17fYrVH30X7LsW57ELt7jIrXFbFyjkzBDRxNHPiLWUWPq1tKSLJHJK/pub

# ── כתיבה לגיליון (אופציונלי — נדרש Apps Script) ────────────────────────────
# 1. פתח את הגיליון > Extensions > Apps Script
# 2. הדבק את הקוד מ-sheets-setup.js
# 3. הרץ setupSheets() פעם אחת
# 4. Deploy > New deployment > Web App > Execute as: Me > Anyone
# 5. העתק את ה-URL והדבק כאן
VITE_SHEETS_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
